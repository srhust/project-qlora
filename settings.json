{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "cleanupPeriodDays": 30,
  "env": {
    "HTTP_PROXY": "http://127.0.0.1:7890",
    "HTTPS_PROXY": "http://127.0.0.1:7890",
    "NO_PROXY": "localhost,127.0.0.1",
    "ANTHROPIC_BASE_URL": "https://api.deepseek.com/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "",
    "ANTHROPIC_MODEL": "deepseek-v4-pro[1m]",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "deepseek-v4-pro[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek-v4-pro[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-v4-flash",
    "CLAUDE_CODE_SUBAGENT_MODEL": "deepseek-v4-flash",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_NAME": "DeepSeek V4 Pro 1M",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_DESCRIPTION": "DeepSeek V4 Pro with 1M context via Anthropic-compatible API",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_SUPPORTED_CAPABILITIES": "effort,max_effort,thinking,adaptive_thinking,interleaved_thinking",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_NAME": "DeepSeek V4 Pro 1M",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_DESCRIPTION": "DeepSeek V4 Pro with 1M context via Anthropic-compatible API",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_SUPPORTED_CAPABILITIES": "effort,max_effort,thinking,adaptive_thinking,interleaved_thinking",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME": "DeepSeek V4 Flash",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL_DESCRIPTION": "DeepSeek V4 Flash for lightweight background tasks",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL_SUPPORTED_CAPABILITIES": "effort,thinking,adaptive_thinking",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(dir*)",
      "Bash(ls*)",
      "Bash(pwd*)",
      "Bash(type*)",
      "Bash(cat*)",
      "Bash(python --version*)",
      "Bash(node --version*)",
      "Bash(npm --version*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./**/*token*)",
      "Read(./**/*secret*)",
      "Bash(rm -rf*)",
      "Bash(del /s*)",
      "Bash(format*)",
      "Bash(curl *api_key*)",
      "Bash(curl *token*)",
      "Bash(powershell Invoke-WebRequest *token*)"
    ],
    "ask": [
      "Edit",
      "Write",
      "Bash(npm install*)",
      "Bash(pip install*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(pytest*)",
      "Bash(npm test*)",
      "Bash(npm run*)",
      "Bash(python*)"
    ],
    "defaultMode": "default"
  },
  "model": "deepseek-v4-pro[1m]",
  "availableModels": [
    "deepseek-v4-pro[1m]",
    "deepseek-v4-pro",
    "deepseek-v4-flash",
    "opus",
    "sonnet",
    "haiku"
  ],
  "defaultShell": "bash",
  "statusLine": {
    "type": "command",
    "command": "echo Claude Code · DeepSeek V4 Pro 1M · Light Theme",
    "padding": 1
  },
  "outputStyle": "default",
  "viewMode": "default",
  "language": "Chinese",
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable",
  "tui": "default",
  "prefersReducedMotion": false,
  "theme": "light",
  "showTurnDuration": true,
  "terminalProgressBarEnabled": true
}
